<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

  <changeSet id="008-backfill-report-version-1-content" author="eshevchenko">
    <sql>
      INSERT INTO reporting.report_versions (id, report_id, version_number, content, created_at)
      SELECT gen_random_uuid(), r.id, 1, r.content, r.created_at
      FROM reporting.reports r
      WHERE r.content IS NOT NULL
      AND NOT EXISTS (
      SELECT 1 FROM reporting.report_versions v
      WHERE v.report_id = r.id AND v.version_number = 1
      );
    </sql>
    <rollback></rollback>
  </changeSet>

  <changeSet id="008-drop-reports-content" author="eshevchenko">
    <preConditions onFail="MARK_RAN">
      <columnExists schemaName="reporting" tableName="reports" columnName="content"/>
    </preConditions>

    <dropColumn schemaName="reporting" tableName="reports" columnName="content"/>

    <rollback>
      <addColumn schemaName="reporting" tableName="reports">
        <column name="content" type="BYTEA"/>
      </addColumn>
    </rollback>
  </changeSet>

</databaseChangeLog>