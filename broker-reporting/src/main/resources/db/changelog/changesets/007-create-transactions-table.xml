<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

  <changeSet id="007-create-transactions-table" author="eshevchenko">

    <createTable schemaName="integration" tableName="transactions">
      <column name="id" type="UUID">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="client_id" type="UUID">
        <constraints nullable="false"/>
      </column>
      <column name="amount" type="NUMERIC(19,2)">
        <constraints nullable="false"/>
      </column>
      <column name="currency" type="VARCHAR(3)">
        <constraints nullable="false"/>
      </column>
      <column name="status" type="VARCHAR(30)">
        <constraints nullable="false"/>
      </column>
      <column name="created_at"
        type="TIMESTAMP WITH TIME ZONE">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <createIndex
      schemaName="integration"
      tableName="transactions"
      indexName="idx_transactions_client_created">

      <column name="client_id"/>
      <column name="created_at"/>
    </createIndex>

    <createIndex
      schemaName="integration"
      tableName="transactions"
      indexName="idx_transactions_status">

      <column name="status"/>
    </createIndex>
  </changeSet>
</databaseChangeLog>