<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

  <changeSet id="006-create-clients-table" author="eshevchenko">

    <createTable schemaName="dictionary" tableName="clients">
      <column name="id" type="UUID">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="full_name" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="inn" type="VARCHAR(12)">
        <constraints nullable="false"/>
      </column>
      <column name="email" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <createIndex
      schemaName="dictionary"
      tableName="clients"
      indexName="idx_clients_inn">
      <column name="inn"/>
    </createIndex>

    <createIndex
      schemaName="dictionary"
      tableName="clients"
      indexName="idx_clients_email">
      <column name="email"/>
    </createIndex>

    <addUniqueConstraint
      schemaName="dictionary"
      tableName="clients"
      columnNames="inn"
      constraintName="uq_clients_inn"/>

    <addUniqueConstraint
      schemaName="dictionary"
      tableName="clients"
      columnNames="email"
      constraintName="uq_clients_email"/>
  </changeSet>

</databaseChangeLog>