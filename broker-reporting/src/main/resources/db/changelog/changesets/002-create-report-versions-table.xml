<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

  <changeSet id="002-create-report-versions-table" author="eshevchenko">
    <createTable schemaName="reporting" tableName="report_versions">
      <column name="id" type="UUID">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="report_id" type="UUID">
        <constraints nullable="false"/>
      </column>
      <column name="version_number" type="INT">
        <constraints nullable="false"/>
      </column>
      <column name="content" type="BYTEA"/>
      <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <addForeignKeyConstraint
      baseTableSchemaName="reporting"
      baseTableName="report_versions"
      baseColumnNames="report_id"
      referencedTableSchemaName="reporting"
      referencedTableName="reports"
      referencedColumnNames="id"
      constraintName="fk_report_versions_report_id"
      onDelete="CASCADE"/>

    <createIndex
      schemaName="reporting"
      tableName="report_versions"
      indexName="idx_report_versions_report_id">
      <column name="report_id"/>
    </createIndex>

    <addUniqueConstraint
      schemaName="reporting"
      tableName="report_versions"
      columnNames="report_id, version_number"
      constraintName="uq_report_versions_report_version"/>
  </changeSet>

</databaseChangeLog>