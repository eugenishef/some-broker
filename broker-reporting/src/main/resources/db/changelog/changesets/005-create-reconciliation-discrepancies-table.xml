<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

  <changeSet id="005-create-reconciliation-discrepancies-table" author="eshevchenko">
    <createTable schemaName="reconciliation" tableName="reconciliation_discrepancies">
      <column name="id" type="UUID">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="reconciliation_id" type="UUID">
        <constraints nullable="false"/>
      </column>
      <column name="field" type="VARCHAR(100)">
        <constraints nullable="false"/>
      </column>
      <column name="expected" type="VARCHAR(255)"/>
      <column name="actual" type="VARCHAR(255)"/>
    </createTable>

    <addForeignKeyConstraint
      baseTableSchemaName="reconciliation"
      baseTableName="reconciliation_discrepancies"
      baseColumnNames="reconciliation_id"
      referencedTableSchemaName="reconciliation"
      referencedTableName="reconciliations"
      referencedColumnNames="id"
      constraintName="fk_discrepancies_reconciliation_id"
      onDelete="CASCADE"/>

    <createIndex
      schemaName="reconciliation"
      tableName="reconciliation_discrepancies"
      indexName="idx_reconciliation_discrepancy_reconciliation">
      <column name="reconciliation_id"/>
    </createIndex>
  </changeSet>

</databaseChangeLog>