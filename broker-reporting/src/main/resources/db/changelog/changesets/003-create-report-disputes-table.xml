<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

  <changeSet id="003-create-report-disputes-table" author="eshevchenko">
    <createTable schemaName="dispute" tableName="report_disputes">
      <column name="id" type="UUID">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="report_id" type="UUID">
        <constraints nullable="false"/>
      </column>
      <column name="comment" type="TEXT">
        <constraints nullable="false"/>
      </column>
      <column name="status" type="VARCHAR(30)">
        <constraints nullable="false"/>
      </column>
      <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <addForeignKeyConstraint
      baseTableSchemaName="dispute"
      baseTableName="report_disputes"
      baseColumnNames="report_id"
      referencedTableSchemaName="reporting"
      referencedTableName="reports"
      referencedColumnNames="id"
      constraintName="fk_report_disputes_report_id"
      onDelete="CASCADE"/>

    <createIndex
      schemaName="dispute"
      tableName="report_disputes"
      indexName="idx_report_disputes_report_status">
      <column name="report_id"/>
      <column name="status"/>
    </createIndex>
  </changeSet>

  <changeSet id="003b-create-report-dispute-operations-table" author="eshevchenko">
    <createTable schemaName="dispute" tableName="report_dispute_operations">
      <column name="dispute_id" type="UUID">
        <constraints nullable="false"/>
      </column>
      <column name="operation_id" type="UUID">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <addPrimaryKey
      schemaName="dispute"
      tableName="report_dispute_operations"
      columnNames="dispute_id,operation_id"
      constraintName="pk_report_dispute_operations"/>

    <createIndex
      schemaName="dispute"
      tableName="report_dispute_operations"
      indexName="idx_report_dispute_operations_operation_id">
      <column name="operation_id"/>
    </createIndex>

    <addForeignKeyConstraint
      baseTableSchemaName="dispute"
      baseTableName="report_dispute_operations"
      baseColumnNames="dispute_id"
      referencedTableSchemaName="dispute"
      referencedTableName="report_disputes"
      referencedColumnNames="id"
      constraintName="fk_dispute_operations_dispute_id"
      onDelete="CASCADE"/>
  </changeSet>

</databaseChangeLog>