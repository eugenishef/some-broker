<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

  <changeSet id="009-add-is-actual-report-versions" author="eshevchenko">
    <addColumn tableName="report_versions" schemaName="reporting">
      <column name="is_actual" type="boolean" defaultValueBoolean="false">
        <constraints nullable="false"/>
      </column>
    </addColumn>

    <sql>
      CREATE UNIQUE INDEX uq_report_versions_actual
      ON reporting.report_versions (report_id)
      WHERE is_actual = true;
    </sql>
  </changeSet>
</databaseChangeLog>