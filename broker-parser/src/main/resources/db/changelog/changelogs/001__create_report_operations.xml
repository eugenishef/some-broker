<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

  <changeSet id="001-create-report-operations-table" author="eshevchenko">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists schemaName="reporting" tableName="report_operations"/>
      </not>
    </preConditions>

    <createTable schemaName="reporting" tableName="report_operations">
      <column name="id" type="UUID">
        <constraints primaryKey="true"
          nullable="false"/>
      </column>
      <column name="report_id" type="UUID">
        <constraints nullable="false"/>
      </column>
      <column name="operation_id" type="UUID">
        <constraints nullable="false"/>
      </column>
      <column name="operation_date" type="DATE"/>
      <column name="amount" type="DECIMAL(19,2)"/>
      <column name="currency" type="VARCHAR(10)"/>
      <column name="operation_type" type="VARCHAR(50)"/>
      <column name="status" type="VARCHAR(30)"/>
    </createTable>

    <createIndex
      schemaName="reporting"
      tableName="report_operations"
      indexName="idx_report_operations_report_id">
      <column name="report_id"/>
    </createIndex>

    <createIndex
      schemaName="reporting"
      tableName="report_operations"
      indexName="idx_report_operations_operation_id">
      <column name="operation_id"/>
    </createIndex>

    <createIndex
      schemaName="reporting"
      tableName="report_operations"
      indexName="idx_report_operations_operation_date">
      <column name="operation_date"/>
    </createIndex>
    <rollback>
      <dropTable schemaName="reporting" tableName="report_operations"/>
    </rollback>
  </changeSet>
</databaseChangeLog>